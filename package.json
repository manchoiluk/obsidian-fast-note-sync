{
  "name": "fast-note-sync",
  "version": "2.0.0",
  "description": "Privately deployable real-time multi-device note synchronization, supporting desktop and mobile devices.",
  "main": "main.js",
  "scripts": {
    "dev": "npm-run-all2 --parallel devts devcss",
    "devts": "node esbuild.config.mjs",
    "devcss": "sass --watch src/styles.scss styles.css && tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
    "ver": "node ./scripts/update-version.js",
    "dist": "npx tsx scripts/copy-dist.ts",
    "translate": "node scripts/translate-i18n.mjs --model Qwen/Qwen3.6-35B-A3B",
    "t": "node scripts/translate-i18n.mjs --model Qwen/Qwen3.6-35B-A3B"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^25.6.2",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@typescript-eslint/eslint-plugin": "^8.59.2",
    "@typescript-eslint/parser": "^8.59.2",
    "esbuild": "^0.24.2",
    "eslint": "^9.39.4",
    "npm-run-all2": "^8.0.4",
    "obsidian": "^1.12.3",
    "sass": "^1.99.0",
    "tslib": "^2.8.1",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@codemirror/state": "6.5.0",
    "@codemirror/view": "6.38.6",
    "file-type": "^21.3.1",
    "jszip": "^3.10.1",
    "pinyin-pro": "^3.28.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "packageManager": "pnpm@9.12.3+sha512.cce0f9de9c5a7c95bef944169cc5dfe8741abfb145078c0d508b868056848a87c81e626246cb60967cbd7fd29a6c062ef73ff840d96b3c86c40ac92cf4a813ee"
}
